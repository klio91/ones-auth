# Database
ONES_AUTH_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ones
ONES_AUTH_DB_ECHO=false

# Keycloak OIDC
ONES_AUTH_KEYCLOAK_URL=http://localhost:8080
ONES_AUTH_KEYCLOAK_REALM=ones
ONES_AUTH_KEYCLOAK_CLIENT_ID=ones
ONES_AUTH_KEYCLOAK_CLIENT_SECRET=<your-client-secret>
ONES_AUTH_KEYCLOAK_REDIRECT_URI=http://localhost:8000/auth/callback

# Keycloak Admin API
ONES_AUTH_KEYCLOAK_ADMIN_CLIENT_ID=ones-auth-admin
ONES_AUTH_KEYCLOAK_ADMIN_CLIENT_SECRET=<your-admin-secret>

# Cookie
ONES_AUTH_COOKIE_SECURE=false

# Server
ONES_AUTH_HOST=0.0.0.0
ONES_AUTH_PORT=8080
